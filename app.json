{
  "expo": {
    "name": "Semora",
    "slug": "semora",
    "version": "1.3",
    "runtimeVersion": "1.0.0",
    "icon": "./assets/images/icon.png",
    "scheme": "semora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0b24"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rajeshpanta.syllabussnap",
      "buildNumber": "17",
      "appleTeamId": "7T9897GFKH",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.rajeshpanta.syllabussnap"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@bacons/apple-targets",
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Semora uses Face ID to verify your identity before deleting your account."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-calendar",
        {
          "calendarPermission": "Semora needs calendar access to sync your task due dates."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6B46C1"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Semora accesses your photo library so you can select existing images of your syllabus to import. For example, choose a saved screenshot of your course syllabus and Semora will extract assignments, exam dates, and due dates into your semester calendar.",
          "cameraPermission": "Semora uses your camera to take photos of printed or paper syllabus pages. For example, snap a photo of your professor's printed syllabus and Semora will automatically extract assignments, exam dates, and due dates into your semester calendar.",
          "microphonePermission": false
        }
      ],
      "expo-document-picker",
      "react-native-iap",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.106719403227-9qu6ehvh8d12a24l978ljdd4j7cda9pl"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "063fbdf9-33e3-49b4-8b0b-ba9d6f18490b"
      }
    },
    "owner": "smallpantas-organization"
  }
}
